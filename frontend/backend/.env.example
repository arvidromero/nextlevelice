# Cadena de conexión a SQL Server
# Formato: sqlserver://HOST:PUERTO;database=NOMBRE_BD;user=USUARIO;password=PASSWORD;trustServerCertificate=true
DATABASE_URL="sqlserver://localhost:1433;database=NextLevelIce;user=sa;password=TU_PASSWORD;trustServerCertificate=true"

# Secreto para firmar tokens JWT (genera uno largo y aleatorio, no lo compartas)
JWT_SECRET="cambia-esto-por-algo-largo-y-aleatorio"

# Puerto donde corre la API
PORT=4000
